# ===== Database =====
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=ptit
MYSQL_PORT=3307

# ===== Backend =====
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/ptit?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_mysql_root_password

# >= 64 ky tu. Sinh bang: openssl rand -base64 64
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars

# Gmail SMTP - dung App Password (https://myaccount.google.com/apppasswords)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# Admin mac dinh tao luc khoi dong (DataInitializer)
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change_me

# ===== Frontend =====
# Khi chay Docker (cung domain) de trong; khi dev local de http://localhost:8080
VITE_API_BASE=

# CORS - cach nhau dau phay
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost
